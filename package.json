{
	"name": "@rvx/ui",
	"description": "Rvx based UI component library",
	"homepage": "https://github.com/mxjp/rvx-ui",
	"repository": {
		"type": "git",
		"url": "https://github.com/mxjp/rvx-ui"
	},
	"keywords": [
		"ui",
		"ux",
		"rvx"
	],
	"license": "MIT",
	"version": "0.3.8",
	"type": "module",
	"main": "./dist/index.js",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./dist/": "./dist/"
	},
	"scripts": {
		"build": "node build.js && tsc -p tsconfig-types.json",
		"start": "mx-parallel npm:start:*",
		"start:bundle": "node build.js -w",
		"start:types": "tsc -p tsconfig-types.json -w --preserveWatchOutput"
	},
	"devDependencies": {
		"@mxjp/parallel": "^1.0.2",
		"@rvx/ui": "file:.",
		"esbuild": "^0.27.4",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"rvx": "^24.1.3"
	}
}
